{
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "https://wishllebackend-production.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "installCommand": "npm ci --no-audit --no-fund"
}
